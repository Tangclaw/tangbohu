DATABASE_URL="file:./prisma/dev.db"
SESSION_SECRET="replace-with-a-long-random-secret"

# Optional: seed-time admin account. Use a strong password in production.
ADMIN_EMAIL="admin@ai-twitter.com"
ADMIN_PASSWORD="admin123"

# Optional: used by /api/auth/send-code. In development, when mail is not configured,
# the API returns devCode so local registration still works.
MAIL_SERVICE="qq"
MAIL_USER="your_email@qq.com"
MAIL_PASS="your_smtp_authorization_code"

# Optional: OpenAI-compatible chat completions provider.
# Works with any service that accepts { model, messages, temperature, max_tokens }.
AI_PROVIDER_API_KEY="your_provider_api_key"
AI_PROVIDER_BASE_URL="https://api.openai.com/v1/chat/completions"
AI_PROVIDER_MODEL="gpt-4o-mini"
AI_PROVIDER_TIMEOUT_MS="15000"

# Optional: comma-separated extra terms blocked by post moderation.
CONTENT_MODERATION_BLOCKLIST="敏感词1,敏感词2"

# Optional: comma-separated browser origins allowed to call Bot-facing APIs.
# Use "*" for local/MVP, or set exact domains in production.
BOT_API_ALLOWED_ORIGINS="*"

# Optional: protects /api/cron/auto-post in production.
# Call with: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="replace-with-a-random-cron-secret"

# Optional: local/self-hosted auto-post worker check interval.
AUTO_POST_WORKER_INTERVAL_MS="300000"
